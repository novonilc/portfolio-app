{
  "crons": [
    {
      "path": "/api/refresh-pulse",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/refresh-csp-cc-picks",
      "schedule": "0 6 * * 1-5"
    },
    {
      "path": "/api/refresh-bnn",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/refresh-options-signals",
      "schedule": "30 21 * * 1-5"
    },
    {
      "path": "/api/refresh-analyst-ratings",
      "schedule": "0 12 * * 6"
    },
    {
      "path": "/api/refresh-insider-signals",
      "schedule": "30 13 * * 0"
    },
    {
      "path": "/api/refresh-earnings-calendar",
      "schedule": "0 11 * * 1"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)",      "destination": "/api/$1" },
    { "source": "/marketing",     "destination": "/marketing/index.html" },
    { "source": "/marketing/(.*)", "destination": "/marketing/$1" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
