{
  "crons": [
    {
      "path": "/api/refresh-pulse",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/refresh-bnn",
      "schedule": "0 13 * * 1-5"
    },
    {
      "path": "/api/refresh-options-signals",
      "schedule": "30 21 * * 1-5"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)",      "destination": "/api/$1" },
    { "source": "/marketing",     "destination": "/marketing/index.html" },
    { "source": "/marketing/(.*)", "destination": "/marketing/$1" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
