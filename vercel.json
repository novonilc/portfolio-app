{
  "rewrites": [
    { "source": "/api/(.*)",      "destination": "/api/$1" },
    { "source": "/marketing",     "destination": "/marketing/index.html" },
    { "source": "/marketing/(.*)", "destination": "/marketing/$1" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
